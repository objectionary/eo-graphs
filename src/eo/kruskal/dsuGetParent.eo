# Returns the root parent of node-number, or node-number if it has no parent.
[node-number dsu-list] > dsuGetParent
  # Recursively follows parent links until the root of the set is reached.
  [i] > getter
    ^.dsu-list.at i > parent!
    if. > @
      (parent.as-number.eq -1).not
      ^.getter parent.as-number
      i
  getter node-number > @
