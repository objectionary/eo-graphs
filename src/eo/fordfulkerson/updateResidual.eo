# Pushes bneck units of flow along u to v, updating both residual edges.
[matrix u v bneck] > updateResidual
  setCell matrix u v (((matrix.at u).at v).minus bneck) > forward
  setCell forward v u (((forward.at v).at u).plus bneck) > @
