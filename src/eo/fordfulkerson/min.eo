+version 0.0.0

# Returns the smaller of the two given numbers.
[a b] > min
  if. > @
    a.lt b
    a
    b
  # Returns the first argument when it is the smaller of the two.
  [] +> tests-picks-the-smaller
    (fordfulkerson.min 3 7).eq 3 > @
