+version 0.0.0

# Prim algorithm application, reads a graph and prints its spanning tree.
[args] > primApp
  prim.printResult (prim.algo (prim.graph args)) > @
  # Reads a tiny graph, runs the algorithm and prints its spanning tree.
  [] +> tests-builds-tree-for-tiny-graph
    prim.primApp (* "0" "1" "5") > @
