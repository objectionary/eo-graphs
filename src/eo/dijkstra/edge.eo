# Graph edge in adjacency list, leading to vertex 'to' with the given 'weight'.
[to weight] > edge
  # Confirms an edge keeps the destination vertex it was built with.
  [] +> tests-keeps-destination
    (dijkstra.edge 3 7).to.eq 3 > @
